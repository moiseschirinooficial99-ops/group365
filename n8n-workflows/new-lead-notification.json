{
  "name": "360GROUP — Nuevo Lead → WhatsApp Agente",
  "nodes": [
    {
      "name": "Webhook Lead",
      "type": "n8n-nodes-base.webhook",
      "parameters": { "path": "new-lead", "httpMethod": "POST", "responseMode": "onReceived" },
      "position": [240, 300]
    },
    {
      "name": "Format Message",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const { lead, score, redirect } = $input.first().json;\nconst emoji = redirect === 'exp' ? '🔵' : redirect === 'personal' ? '🟠' : '🟢';\nreturn [{ json: { message: `${emoji} NUEVO LEAD 360GROUP\\n\\n👤 ${lead?.name || '-'}\\n📧 ${lead?.email || '-'}\\n📱 ${lead?.phone || '-'}\\n💰 €${lead?.budget_max || '-'}\\n📊 Score: ${score}%\\n🎯 ${redirect?.toUpperCase()}`, to: process.env.AGENT_PHONE } }];"
      },
      "position": [460, 300]
    },
    {
      "name": "Send WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{$env.WA_PHONE_ID}}/messages",
        "headers": { "Authorization": "=Bearer {{$env.WA_TOKEN}}", "Content-Type": "application/json" },
        "body": "={ \"messaging_product\": \"whatsapp\", \"to\": \"{{$json.to}}\", \"type\": \"text\", \"text\": { \"body\": \"{{$json.message}}\" } }"
      },
      "position": [680, 300]
    }
  ],
  "connections": {
    "Webhook Lead": { "main": [[{ "node": "Format Message", "type": "main", "index": 0 }]] },
    "Format Message": { "main": [[{ "node": "Send WhatsApp", "type": "main", "index": 0 }]] }
  }
}
