{
  "name": "360GROUP — WhatsApp Bot con IA",
  "nodes": [
    {
      "name": "WA Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": { "path": "wa-bot-360", "httpMethod": "POST", "responseMode": "onReceived" },
      "position": [240, 300]
    },
    {
      "name": "Extract",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst msg = body?.entry?.[0]?.changes?.[0]?.value?.messages?.[0];\nif (!msg) return [];\nreturn [{ json: { from: msg.from, text: msg.text?.body || '', type: msg.type } }];"
      },
      "position": [460, 300]
    },
    {
      "name": "AI Response",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "parameters": {
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Eres asesor inmobiliario de GROUP 360 INICIATIVAS. Misión: calificar leads y orientarlos. Siempre en español, profesional y cercano. Si preguntan por propiedades, pregunta su presupuesto y zona. Máximo 3 líneas por respuesta. No hagas promesas de precio. Si es urgente o complejo, di que un especialista les llamará."
            },
            { "role": "user", "content": "={{$json.text}}" }
          ]
        }
      },
      "position": [680, 300]
    },
    {
      "name": "Reply WA",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{$env.WA_PHONE_ID}}/messages",
        "headers": { "Authorization": "=Bearer {{$env.WA_TOKEN}}", "Content-Type": "application/json" },
        "body": "={ \"messaging_product\": \"whatsapp\", \"to\": \"{{$node.Extract.json.from}}\", \"type\": \"text\", \"text\": { \"body\": \"{{$json.message.content}}\" } }"
      },
      "position": [900, 300]
    }
  ],
  "connections": {
    "WA Webhook": { "main": [[{ "node": "Extract", "type": "main", "index": 0 }]] },
    "Extract": { "main": [[{ "node": "AI Response", "type": "main", "index": 0 }]] },
    "AI Response": { "main": [[{ "node": "Reply WA", "type": "main", "index": 0 }]] }
  }
}
