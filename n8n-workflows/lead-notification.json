{
  "name": "360GROUP — Nuevo Lead → Notificación WhatsApp Agente",
  "nodes": [
    {
      "name": "Webhook Lead",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "new-lead",
        "httpMethod": "POST",
        "responseMode": "onReceived"
      },
      "position": [240, 300]
    },
    {
      "name": "Format Message",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const { lead, score, redirect } = $input.first().json;\nconst emoji = redirect === 'exp' ? '🔵' : redirect === 'personal' ? '🟠' : '🟢';\nconst msg = `${emoji} *NUEVO LEAD 360GROUP*\n\n👤 ${lead?.name || '-'}\n📧 ${lead?.email || '-'}\n📱 ${lead?.phone || '-'}\n💰 Presupuesto: €${lead?.budget_max || '-'}\n📍 Zona: ${lead?.preferred_zone || '-'}\n📊 Score: ${score}%\n🎯 Ruta: ${redirect?.toUpperCase()}\n📌 Fuente: ${lead?.source}`;\nreturn [{ json: { message: msg, to: process.env.AGENT_PHONE } }];"
      },
      "position": [460, 300]
    },
    {
      "name": "Send WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{$env.WA_PHONE_ID}}/messages",
        "headers": {
          "Authorization": "=Bearer {{$env.WA_TOKEN}}",
          "Content-Type": "application/json"
        },
        "body": "={\"messaging_product\":\"whatsapp\",\"to\":\"{{$json.to}}\",\"type\":\"text\",\"text\":{\"body\":\"{{$json.message}}\"}}"
      },
      "position": [680, 300]
    },
    {
      "name": "Save to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "PATCH",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/leads?id=eq.{{$node['Webhook Lead'].json.lead.id}}",
        "headers": {
          "apikey": "={{$env.SUPABASE_KEY}}",
          "Authorization": "=Bearer {{$env.SUPABASE_KEY}}",
          "Content-Type": "application/json"
        },
        "body": "={\"status\":\"contacted\",\"notes\":\"Notificado via n8n\"}"
      },
      "position": [680, 480]
    }
  ],
  "connections": {
    "Webhook Lead": {
      "main": [[{ "node": "Format Message", "type": "main", "index": 0 }]]
    },
    "Format Message": {
      "main": [
        [{ "node": "Send WhatsApp", "type": "main", "index": 0 }],
        [{ "node": "Save to Supabase", "type": "main", "index": 0 }]
      ]
    }
  }
}
