{
  "name": "360GROUP — Telegram → Publicar Propiedad",
  "nodes": [
    {
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "parameters": { "updates": ["message"], "additionalFields": {} },
      "position": [240, 300]
    },
    {
      "name": "Has Photo?",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{$json.message.photo !== undefined}}", "value2": true }]
        }
      },
      "position": [460, 300]
    },
    {
      "name": "Parse with AI",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "parameters": {
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Extrae datos de propiedad inmobiliaria del texto y devuelve JSON con: title, price (número), location, zone, bedrooms (número), bathrooms (número), area_sqm (número), estimated_roi (número), channel (exp/bancaria/personal/alquiler), property_type (apartment/house/villa). Solo JSON, sin explicación."
            },
            { "role": "user", "content": "={{$json.message.caption || $json.message.text || 'Sin datos'}}" }
          ]
        }
      },
      "position": [680, 200]
    },
    {
      "name": "Save to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/properties",
        "headers": {
          "apikey": "={{$env.SUPABASE_KEY}}",
          "Authorization": "=Bearer {{$env.SUPABASE_KEY}}",
          "Content-Type": "application/json",
          "Prefer": "return=representation"
        },
        "body": "={{JSON.parse($node['Parse with AI'].json.message.content)}}"
      },
      "position": [900, 200]
    },
    {
      "name": "Confirm Telegram",
      "type": "n8n-nodes-base.telegram",
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{$json.message.chat.id}}",
        "text": "✅ Propiedad publicada en la web: {{$node['Save to Supabase'].json[0].title}}"
      },
      "position": [1120, 200]
    }
  ],
  "connections": {
    "Telegram Trigger": { "main": [[{ "node": "Has Photo?", "type": "main", "index": 0 }]] },
    "Has Photo?": { "main": [[{ "node": "Parse with AI", "type": "main", "index": 0 }]] },
    "Parse with AI": { "main": [[{ "node": "Save to Supabase", "type": "main", "index": 0 }]] },
    "Save to Supabase": { "main": [[{ "node": "Confirm Telegram", "type": "main", "index": 0 }]] }
  }
}
